# Agent Platform 环境变量配置（Python + FastAPI + LangChain + LangGraph + Milvus + Redis + PostgreSQL）

# Redis
REDIS_URL=redis://localhost:6379/0

# PostgreSQL
PG_DSN=postgresql://postgres:postgres@localhost:5432/agent_platform

# Milvus (Docker Standalone 默认 gRPC 端口)
MILVUS_HOST=localhost
MILVUS_PORT=19530

# LLM（DeepSeek，OpenAI 兼容）
DEEPSEEK_API_KEY=sk-your-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Embedding（支持动态切换：dashscope / openai_compatible / sentence_transformers）
EMBEDDING_PROVIDER=dashscope
EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_API_KEY=sk-your-api-key

# Retrieval
RETRIEVAL_TOP_K=5
RERANK_ENABLED=true

# Circuit Breaker
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT=30.0

# Tracing（console / otel）
TRACER_BACKEND=console
OTEL_ENDPOINT=http://localhost:4317

# Server
HOST=0.0.0.0
PORT=8000
